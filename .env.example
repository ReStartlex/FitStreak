# ──────────────────────────────────────────────
#  FitStreak — Production environment
#  Copy to `.env.local` for local dev
# ──────────────────────────────────────────────

# PostgreSQL (Neon recommended). Format:
# postgres://USER:PASS@HOST/DB?sslmode=require
# DATABASE_URL → pooled connection (host has `-pooler`), used at runtime
# DIRECT_URL   → direct connection (no `-pooler`), used by Prisma migrations
DATABASE_URL=
DIRECT_URL=

# Auth.js secret (generate via `openssl rand -base64 32` or `npx auth secret`)
AUTH_SECRET=
NEXTAUTH_SECRET=

# Public URL of your deployment
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# In production both should point to https://fitstreak.ru

# Google OAuth (https://console.cloud.google.com → OAuth 2.0)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Yandex ID (https://oauth.yandex.ru)
AUTH_YANDEX_ID=
AUTH_YANDEX_SECRET=

# VK ID (https://id.vk.com/business/go)
AUTH_VK_ID=
AUTH_VK_SECRET=

# Resend (https://resend.com/api-keys) — optional but recommended
RESEND_API_KEY=
RESEND_FROM="FitStreak <noreply@mail.fitstreak.ru>"

# SEO / canonical site URL. Optional override — when unset the app
# falls back to NEXT_PUBLIC_APP_URL (and ultimately to the canonical
# https://fitstreak.ru). Use this to pin a different host for staging.
NEXT_PUBLIC_SITE_URL=https://fitstreak.ru

# Search-console verification codes (paste the random token from each
# webmaster tool). Empty values render no meta tag.
GOOGLE_SITE_VERIFICATION=
YANDEX_SITE_VERIFICATION=
BING_SITE_VERIFICATION=

# Optional: turn on/off features
ENABLE_OAUTH_GOOGLE=true
ENABLE_OAUTH_YANDEX=true
ENABLE_OAUTH_VK=true
