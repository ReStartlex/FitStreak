// FitStreak production schema
// Postgres on Neon, Prisma adapter for Auth.js v5.
// Run `npm run db:push` for first deploy or `npm run db:migrate` for tracked migrations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ───────────────────────── Auth ─────────────────────────

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  emailVerified DateTime?
  name          String?
  username      String?  @unique
  image         String?
  passwordHash  String?
  locale        String   @default("ru")

  // Onboarding flag — true after body metrics are filled
  onboarded     Boolean  @default(false)

  // Body metrics (denormalised for fast access)
  gender        Gender?
  age           Int?
  heightCm      Int?
  weightKg      Int?

  fitnessLevel  FitnessLevel?
  goal          Goal?

  // Aggregated stats (kept in sync via Activity API)
  totalEnergy   Int      @default(0)
  totalXp       Int      @default(0)
  level         Int      @default(1)
  currentStreak Int      @default(0)
  bestStreak    Int      @default(0)
  lastActiveAt  DateTime?

  // Streak protection (Duolingo-style freezes)
  streakFreezes      Int      @default(2)
  lastFreezeUsedAt   DateTime?
  freezesEarnedTotal Int      @default(2)

  // Reminder prefs
  reminders     ReminderConfig?

  // Plan / subscription
  plan          Plan     @default(FREE)

  // Privacy: when false, profile and activity are not exposed publicly
  // (still visible in leaderboard if user opted in; toggle is independent).
  isPublic      Boolean  @default(true)
  showOnLeaderboard Boolean @default(true)

  // Relations
  accounts      Account[]
  sessions      Session[]
  activity      ActivityRecord[]
  participations ChallengeParticipant[]
  achievements  UserAchievement[]
  follows       Follow[] @relation("Follower")
  followers     Follow[] @relation("Following")
  notifications      Notification[] @relation("NotificationOwner")
  triggeredNotifs    Notification[] @relation("NotificationActor")
  reactions     ActivityReaction[]
  blocksMade    Block[] @relation("Blocker")
  blocksReceived Block[] @relation("Blocked")
  reportsMade    Report[] @relation("Reporter")
  reportsReceived Report[] @relation("Reported")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([totalEnergy])
  @@index([level])
  @@index([totalXp])
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ───────────────────────── Activity ─────────────────────────

model ActivityRecord {
  id           String   @id @default(cuid())
  userId       String
  exerciseId   String
  amount       Int
  energy       Int
  xp           Int
  kcal         Int
  source       ActivitySource @default(MANUAL)
  recordedAt   DateTime @default(now())
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions ActivityReaction[]

  @@index([userId, recordedAt])
  @@index([recordedAt])
  @@index([userId, exerciseId])
}

model ActivityReaction {
  id         String   @id @default(cuid())
  recordId   String
  userId     String
  emoji      ReactionEmoji
  createdAt  DateTime @default(now())

  record ActivityRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([recordId, userId, emoji])
  @@index([recordId])
}

enum ReactionEmoji {
  FIRE
  CLAP
  STRONG
  HEART
  ROCKET
}

enum ActivitySource {
  MANUAL
  IMPORT
  MOBILE
  HEALTHKIT
  GOOGLE_FIT
}

// ───────────────────────── Challenges ─────────────────────────

model Challenge {
  id           String   @id @default(cuid())
  slug         String   @unique
  titleRu      String
  titleEn      String
  descRu       String   @db.Text
  descEn       String   @db.Text
  metric       ChallengeMetric
  exerciseId   String?
  goal         Int
  durationDays Int
  difficulty   ChallengeDifficulty @default(MEDIUM)
  rewardXp     Int      @default(0)
  rewardEnergy Int      @default(0)
  participantsCount Int @default(0)
  isFeatured   Boolean  @default(false)
  // PUBLIC = anyone can join, FRIENDS = invite-only (defer), PERSONAL = single owner
  type         ChallengeType @default(PUBLIC)
  createdById  String?
  endsAt       DateTime?
  createdAt    DateTime @default(now())

  participants ChallengeParticipant[]

  @@index([isFeatured])
  @@index([type])
  @@index([createdById])
}

enum ChallengeType {
  PUBLIC
  FRIENDS
  PERSONAL
}

enum ChallengeMetric {
  REPS
  KM
  MINUTES
  ENERGY
  STREAK_DAYS
  DAYS_ACTIVE
}

enum ChallengeDifficulty {
  EASY
  MEDIUM
  HARD
  ELITE
}

model ChallengeParticipant {
  id          String   @id @default(cuid())
  userId      String
  challengeId String
  progress    Int      @default(0)
  completed   Boolean  @default(false)
  joinedAt    DateTime @default(now())
  completedAt DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
  @@index([challengeId, progress])
}

// ───────────────────────── Reminders ─────────────────────────

model ReminderConfig {
  id          String   @id @default(cuid())
  userId      String   @unique
  enabled     Boolean  @default(true)
  morningTime String   @default("08:00")
  eveningTime String   @default("21:00")
  weekendsOff Boolean  @default(false)
  smartMode   Boolean  @default(true)
  pushEnabled Boolean  @default(true)
  emailEnabled Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ───────────────────────── Achievements ─────────────────────────

model Achievement {
  id          String   @id @default(cuid())
  slug        String   @unique
  titleRu     String
  titleEn     String
  descRu      String
  descEn      String
  icon        String
  tier        AchievementTier @default(BRONZE)
  rewardXp    Int      @default(0)

  users UserAchievement[]
}

enum AchievementTier {
  BRONZE
  SILVER
  GOLD
  ELITE
  LEGEND
}

model UserAchievement {
  id              String   @id @default(cuid())
  userId          String
  achievementId   String
  count           Int      @default(1)
  unlockedAt      DateTime @default(now())
  lastEarnedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
}

// ───────────────────────── Social ─────────────────────────

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  reason    String?
  createdAt DateTime @default(now())

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

// ───────────────────────── Notifications ─────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String   // recipient
  actorId   String?  // who triggered, null = system
  type      NotificationType
  // Free-form payload kept as JSON-ish text fields to avoid migrations.
  // We store small primitives only (title slugs, deltas, ids).
  data      Json?
  readAt    DateTime?
  createdAt DateTime @default(now())

  user  User  @relation("NotificationOwner", fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

enum NotificationType {
  FOLLOW
  LEVEL_UP
  ACHIEVEMENT
  STREAK_MILESTONE
  STREAK_AT_RISK
  CHALLENGE_DONE
  CHALLENGE_INVITE
  LEADERBOARD_OVERTAKE
  LEADERBOARD_TOP3
  SYSTEM
}

// ───────────────────────── RankSnapshots ─────────────────────────

/**
 * One row per (scope, observer?, user, day). Captured by the
 * `/api/cron/leaderboard-overtake` cron once a day; the next run
 * compares yesterday's rows with today's to surface position changes
 * without spamming on every activity log.
 */
model RankSnapshot {
  id         String    @id @default(cuid())
  scope      RankScope
  observerId String?
  userId     String
  rank       Int
  value      Int
  capturedOn DateTime  @db.Date

  @@unique([scope, observerId, userId, capturedOn])
  @@index([scope, capturedOn])
  @@index([userId, capturedOn])
}

enum RankScope {
  /** Top performers globally, ordered by current streak. */
  GLOBAL_STREAK
  /** Per-observer ranking inside their friend circle by today's energy. */
  FRIENDS_TODAY
}

// ───────────────────────── Reports ─────────────────────────

/**
 * Lightweight abuse report. The reporter automatically also blocks
 * the reported user (a separate Block row), so they get safety
 * benefits immediately without waiting for triage.
 */
model Report {
  id          String        @id @default(cuid())
  reporterId  String
  targetId    String
  category    ReportCategory
  comment     String?       @db.Text
  status      ReportStatus  @default(OPEN)
  createdAt   DateTime      @default(now())
  resolvedAt  DateTime?
  resolvedBy  String?

  reporter User @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  target   User @relation("Reported", fields: [targetId], references: [id], onDelete: Cascade)

  @@index([targetId, status])
  @@index([reporterId])
}

enum ReportCategory {
  SPAM
  HARASSMENT
  IMPERSONATION
  CHEATING
  INAPPROPRIATE
  OTHER
}

enum ReportStatus {
  OPEN
  REVIEWING
  RESOLVED
  DISMISSED
}

// ───────────────────────── Waitlist ─────────────────────────

model Waitlist {
  id        String   @id @default(cuid())
  email     String
  plan      Plan
  source    String?
  locale    String   @default("ru")
  createdAt DateTime @default(now())

  @@unique([email, plan])
}

// ───────────────────────── Enums ─────────────────────────

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum FitnessLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ATHLETE
}

enum Goal {
  HEALTH
  WEIGHT_LOSS
  STAMINA
  MUSCLE
  COMPETITIVE
}

enum Plan {
  FREE
  PRO
  TEAM
}
